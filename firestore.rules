rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to validate document ID parameters to guard against ID Poisoning and Denial of Wallet
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate common keys and data sizes
    function isStringWithinLimit(val, limit) {
      return val is string && val.size() <= limit;
    }

    // Teachers collection rules
    match /teachers/{nip} {
      allow read: if true;
      allow create, update: if isValidId(nip) && 
        request.resource.data.nama is string && 
        isStringWithinLimit(request.resource.data.nama, 100);
      allow delete: if true;
    }

    // Classes collection rules
    match /classes/{id} {
      allow read: if true;
      allow create, update: if isValidId(id) && 
        request.resource.data.nama is string && 
        isStringWithinLimit(request.resource.data.nama, 100);
      allow delete: if true;
    }

    // Students collection rules
    match /students/{nisn} {
      allow read: if true;
      allow create, update: if isValidId(nisn) && 
        request.resource.data.nama is string && 
        isStringWithinLimit(request.resource.data.nama, 100);
      allow delete: if true;
    }

    // Holidays collection rules
    match /holidays/{safeId} {
      allow read: if true;
      allow create, update: if isValidId(safeId) && 
        request.resource.data.nama is string && 
        isStringWithinLimit(request.resource.data.nama, 150);
      allow delete: if true;
    }

    // Attendance collection rules
    match /attendance/{safeId} {
      allow read: if true;
      allow create, update: if isValidId(safeId) && 
        request.resource.data.status is string && 
        request.resource.data.date is string;
      allow delete: if true;
    }
  }
}
